FROM python:3.10-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    iverilog \
    gcc \
    g++ \
    make \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    cocotb>=2.0 \
    pytest \
    cocotb-bus

RUN mkdir -p /code/rtl /code/rundir /src

WORKDIR /code

CMD ["sleep", "infinity"]
